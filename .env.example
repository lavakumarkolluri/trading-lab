# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ── ClickHouse ────────────────────────────────────────────────────────────────
CH_PASSWORD=changeme                  # REQUIRED — rotate before production

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_USER=admin
MINIO_PASSWORD=changeme               # REQUIRED — use 16+ char random string

# ── VS Code Server ────────────────────────────────────────────────────────────
VSCODE_PASSWORD=changeme              # REQUIRED — rotate before exposing port

# ── Jupyter ───────────────────────────────────────────────────────────────────
JUPYTER_TOKEN=changeme                # REQUIRED — rotate before exposing port

# ── Telegram alerts ───────────────────────────────────────────────────────────
# Get token from @BotFather; find chat_id by messaging @userinfobot
TELEGRAM_BOT_TOKEN=                   # REQUIRED for alerts — rotate if exposed
TELEGRAM_CHAT_ID=                     # REQUIRED for alerts

# ── Kite Connect (Zerodha broker API) ─────────────────────────────────────────
# Generate daily access token at https://kite.trade/connect/login
KITE_API_KEY=                         # REQUIRED for live order execution
KITE_ACCESS_TOKEN=                    # REQUIRED — regenerate daily

# ── GitHub (auto-deploy from master) ──────────────────────────────────────────
# Create a fine-grained PAT with Contents:read permission for this repo
GITHUB_TOKEN=                         # REQUIRED for auto-deploy pull from private repo

# ── LLM APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # Optional — used by gap_analyzer, analysis_agent
GAP_LLM_ENABLED=false
GAP_LLM_MODEL=claude-sonnet-4-6
